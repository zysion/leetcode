class Solution {
public:
    int reverse(int x) {
        int k = 1;
        if(x==INT_MIN) return 0;
        if (x<0) 
        {
            k=-1;
            x = x*(-1);
        }
        int result=0;
        while(x>0)
        {
            if(result!=0)
            {
                if(INT_MAX/result <10) return 0;
            }
            int temp=x%10;
            result=temp+result*10;
            x/=10;
        }
        return result*k;
    }
};